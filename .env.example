# Cloud OCR API (production: deploy server/ocrExtractHandler to your backend)
# Dev: leave empty — Vite serves POST /api/ocr/extract when keys are set below
VITE_OCR_API_URL=

# Server-side OCR keys (never prefix with VITE_ — not exposed to the browser)
OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-4o-mini
GOOGLE_CLOUD_VISION_API_KEY=

# Create at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=

# Admin owner — only this Google account can access /admin (passcode alone is not enough)
VITE_ADMIN_OWNER_EMAIL=

# Admin dashboard passcode (dev default: 7829 when unset in development)
VITE_ADMIN_DASHBOARD_KEY=

# Admin webhook — POST JSON when a member hits the 50-doc production cap
# e.g. Slack incoming webhook, Supabase Edge Function, or email relay
VITE_ADMIN_NOTIFY_WEBHOOK=

# Launch cohort (month-end MVP) — all Pro features, no Razorpay; cap signups
VITE_LAUNCH_COHORT_PRO=true
VITE_LAUNCH_COHORT_MAX_USERS=100

# Supabase (per environment — use prevault-dev / prevault-uat / prevault-prod projects)
# Prod must be Mumbai (ap-south-1) for India data residency
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OAuth redirect origin (fixes PKCE verifier missing when localhost/127.0.0.1 or domains differ)
# Set to the exact origin users load the app from, e.g.:
# - http://localhost:5173
# - https://app.prevault.in
VITE_APP_ORIGIN=

# Demo auth when Supabase is not configured (auto-on in dev). Set false on UAT/Prod.
VITE_DEMO_AUTH=

# Dev only — plan for demo / local sign-in (pro | free | family). Defaults to pro in npm run dev.
VITE_DEV_USER_PLAN=pro

# Client-side vault encryption pepper (set per environment; never commit real prod value)
VITE_VAULT_PEPPER=
