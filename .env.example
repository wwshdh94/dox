# Google OAuth client ID (Web) — enable Google Drive backup
# Create at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=

# Admin owner — only this Google account can access /admin (passcode alone is not enough)
VITE_ADMIN_OWNER_EMAIL=

# Admin dashboard passcode (dev default: 7829 when unset in development)
VITE_ADMIN_DASHBOARD_KEY=

# Admin webhook — POST JSON when a member hits the 50-doc production cap
# e.g. Slack incoming webhook, Supabase Edge Function, or email relay
VITE_ADMIN_NOTIFY_WEBHOOK=
